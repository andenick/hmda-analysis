# HMDA Analysis — example environment configuration
# Copy to .env and edit. NEVER commit a real .env.

# ── Data locations (used by all analysis code) ──
# Where input HMDA / Census data is read from (see data/MANIFEST.md):
DATA_ROOT=./data
# Where outputs are written:
OUTPUT_ROOT=./outputs

# ── Dashboard settings (only for Technical/src/api/ + streamlit_dashboard.py) ──
FLASK_ENV=production
FLASK_DEBUG=False
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret

HOST=0.0.0.0
PORT=5000
ALLOWED_CORS_ORIGINS=http://localhost:3000

CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

LOG_LEVEL=INFO

RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Optional analytics / monitoring (leave blank if unused)
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=
